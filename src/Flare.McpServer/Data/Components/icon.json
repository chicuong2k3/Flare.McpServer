{
  "name": "Icon",
  "displayName": "FlareIcon",
  "category": "Display",
  "description": "Material Symbols icon component with configurable size, fill, weight, and grade.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareIcon.html",
  "parameters": [
    { "name": "Name", "type": "string", "description": "Material icon name (e.g. 'search', 'delete')", "default": "", "required": true },
    { "name": "Size", "type": "Size", "description": "Icon size", "default": "Md", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Icon color", "default": "Default", "required": false },
    { "name": "Fill", "type": "bool", "description": "Use filled icon variant", "default": "false", "required": false },
    { "name": "Weight", "type": "int", "description": "Icon weight (100-700)", "default": "400", "required": false },
    { "name": "Grade", "type": "int", "description": "Icon grade (-50 to 200)", "default": "0", "required": false }
  ],
  "events": [
    { "name": "OnClick", "type": "EventCallback<MouseEventArgs>", "description": "Fired when the icon is clicked" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareIcon Name=\"search\" />",
    "<FlareIcon Name=\"favorite\" Color=\"FlareColor.Error\" Fill=\"true\" />",
    "<FlareIcon Name=\"settings\" Size=\"Size.Lg\" OnClick=\"OpenSettings\" />"
  ],
  "tags": ["icon", "material", "symbol", "visual"]
}

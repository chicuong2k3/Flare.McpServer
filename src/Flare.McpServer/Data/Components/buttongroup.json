{
  "name": "ButtonGroup",
  "displayName": "FlareButtonGroup",
  "category": "Buttons",
  "description": "Group of buttons with shared variant, color, and size.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareButtonGroup.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Grouped FlareButton children", "default": "", "required": true },
    { "name": "Variant", "type": "ButtonVariant", "description": "Shared variant for all buttons", "default": "Filled", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Shared color", "default": "Default", "required": false },
    { "name": "Size", "type": "Size", "description": "Shared size", "default": "Md", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": ["<FlareButtonGroup Variant=\"ButtonVariant.Outlined\">\n    <FlareButton>Left</FlareButton>\n    <FlareButton>Center</FlareButton>\n    <FlareButton>Right</FlareButton>\n</FlareButtonGroup>"],
  "tags": ["button", "group", "toolbar", "actions"]
}

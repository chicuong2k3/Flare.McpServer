{
  "name": "VirtualList",
  "displayName": "FlareVirtualList",
  "category": "DataDisplay",
  "description": "Virtualized scrolling list that only renders visible items for performance.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareVirtualList.html",
  "parameters": [
    { "name": "Items", "type": "IEnumerable<TItem>", "description": "Data items", "default": "", "required": true },
    { "name": "ChildContent", "type": "RenderFragment<TItem>", "description": "Item template", "default": "", "required": true },
    { "name": "ItemHeight", "type": "int", "description": "Fixed item height in pixels", "default": "48", "required": false },
    { "name": "Height", "type": "string", "description": "List container height", "default": "400px", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": ["<FlareVirtualList Items=\"_bigData\" Height=\"500px\" ItemHeight=\"48\">\n    <ItemTemplate>\n        <FlareText>@context.Name</FlareText>\n    </ItemTemplate>\n</FlareVirtualList>"],
  "tags": ["virtualization", "list", "scroll", "performance", "large-data"]
}

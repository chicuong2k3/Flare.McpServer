{
  "name": "Table",
  "displayName": "FlareTable",
  "category": "DataDisplay",
  "description": "Simple read-only table with themed styling, less feature-rich than DataGrid.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareTable.html",
  "parameters": [
    { "name": "Items", "type": "IEnumerable<TItem>", "description": "Table rows", "default": "", "required": true },
    { "name": "ChildContent", "type": "RenderFragment", "description": "Column definitions", "default": "", "required": true },
    { "name": "Hoverable", "type": "bool", "description": "Highlight row on hover", "default": "false", "required": false },
    { "name": "Striped", "type": "bool", "description": "Alternate row colors", "default": "false", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": ["<FlareTable Items=\"_items\" Striped=\"true\">\n    <FlareColumn Field=\"Name\" Title=\"Name\" />\n    <FlareColumn Field=\"Value\" Title=\"Value\" />\n</FlareTable>"],
  "tags": ["data", "table", "display", "rows", "columns"]
}

{
  "name": "Link",
  "displayName": "FlareLink",
  "category": "Navigation",
  "description": "Anchor link component with theme colors, underline options, and icon support.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareLink.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Link text", "default": "", "required": false },
    { "name": "Href", "type": "string", "description": "Destination URL", "default": "", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Link color", "default": "Default", "required": false },
    { "name": "Underline", "type": "LinkUnderline", "description": "Underline style", "default": "Hover", "required": false },
    { "name": "Icon", "type": "string", "description": "Icon to display with link", "default": "", "required": false },
    { "name": "Target", "type": "string", "description": "Link target (_blank, _self, etc.)", "default": "", "required": false }
  ],
  "events": [
    { "name": "OnClick", "type": "EventCallback<MouseEventArgs>", "description": "Fired when the link is clicked" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareLink Href=\"/docs\" Color=\"FlareColor.Primary\">Documentation</FlareLink>",
    "<FlareLink Href=\"https://github.com\" Target=\"_blank\" Icon=\"open_in_new\">GitHub</FlareLink>"
  ],
  "tags": ["link", "anchor", "navigation", "url", "href"]
}

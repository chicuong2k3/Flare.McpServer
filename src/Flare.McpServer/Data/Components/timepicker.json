{
  "name": "TimePicker",
  "displayName": "FlareTimePicker",
  "category": "Inputs",
  "description": "Time picker with clock dial or text input, AM/PM support.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareTimePicker.html",
  "parameters": [
    { "name": "Value", "type": "TimeSpan?", "description": "Selected time", "default": "", "required": false },
    { "name": "ValueChanged", "type": "EventCallback<TimeSpan?>", "description": "Callback when time changes", "default": "", "required": false },
    { "name": "Label", "type": "string", "description": "Field label", "default": "", "required": false },
    { "name": "Use24Hour", "type": "bool", "description": "Use 24-hour format", "default": "false", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Color theme", "default": "Default", "required": false },
    { "name": "Disabled", "type": "bool", "description": "Whether the picker is disabled", "default": "false", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": [
    "<FlareTimePicker @bind-Value=\"_startTime\" Label=\"Start Time\" Use24Hour=\"true\" />"
  ],
  "tags": ["timepicker", "time", "clock", "input", "form"]
}

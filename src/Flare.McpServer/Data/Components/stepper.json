{
  "name": "Stepper",
  "displayName": "FlareStepper",
  "category": "Navigation",
  "description": "Stepper wizard component for multi-step processes with linear/non-linear modes.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareStepper.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Step children", "default": "", "required": true },
    { "name": "ActiveStep", "type": "int", "description": "Current active step index", "default": "0", "required": false },
    { "name": "ActiveStepChanged", "type": "EventCallback<int>", "description": "Callback when step changes", "default": "", "required": false },
    { "name": "Linear", "type": "bool", "description": "Force sequential step progression", "default": "true", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Step indicator color", "default": "Default", "required": false }
  ],
  "events": [],
  "subComponents": ["FlareStep"],
  "examples": [
    "<FlareStepper @bind-ActiveStep=\"_step\" Linear=\"true\">\n    <FlareStep Title=\"Personal\">Name and email</FlareStep>\n    <FlareStep Title=\"Details\">Address info</FlareStep>\n    <FlareStep Title=\"Confirm\">Review and submit</FlareStep>\n</FlareStepper>"
  ],
  "tags": ["stepper", "wizard", "steps", "workflow", "multi-step"]
}

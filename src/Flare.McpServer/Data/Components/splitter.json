{
  "name": "Splitter",
  "displayName": "FlareSplitter",
  "category": "Layout",
  "description": "Resizable split panels with draggable divider, horizontal or vertical.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareSplitter.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Split pane children", "default": "", "required": true },
    { "name": "Direction", "type": "SplitDirection", "description": "Horizontal or Vertical", "default": "Horizontal", "required": false },
    { "name": "Panel1MinSize", "type": "string", "description": "Min size for first panel", "default": "100px", "required": false },
    { "name": "Panel2MinSize", "type": "string", "description": "Min size for second panel", "default": "100px", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": ["<FlareSplitter>\n    <div>Panel 1</div>\n    <div>Panel 2</div>\n</FlareSplitter>"],
  "tags": ["layout", "splitter", "resize", "panels", "divider"]
}

{
  "name": "Chip",
  "displayName": "FlareChip",
  "category": "Display",
  "description": "Chip/tag component for filtering, selection, or displaying categories with optional icons and close button.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareChip.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Chip label content", "default": "", "required": false },
    { "name": "Label", "type": "string", "description": "Simple text label (alternative to ChildContent)", "default": "", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Chip color", "default": "Default", "required": false },
    { "name": "Variant", "type": "Variant", "description": "Visual appearance", "default": "Filled", "required": false },
    { "name": "Size", "type": "Size", "description": "Chip size", "default": "Md", "required": false },
    { "name": "Icon", "type": "string", "description": "Leading icon name", "default": "", "required": false },
    { "name": "Closeable", "type": "bool", "description": "Show close/remove button", "default": "false", "required": false },
    { "name": "Selected", "type": "bool", "description": "Whether the chip is selected", "default": "false", "required": false },
    { "name": "Disabled", "type": "bool", "description": "Whether the chip is disabled", "default": "false", "required": false }
  ],
  "events": [
    { "name": "OnClose", "type": "EventCallback", "description": "Fired when the close button is clicked" },
    { "name": "OnClick", "type": "EventCallback", "description": "Fired when the chip is clicked" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareChip Color=\"FlareColor.Primary\" Closeable=\"true\">React</FlareChip>",
    "<FlareChip Variant=\"Variant.Outlined\" Icon=\"person\">User</FlareChip>"
  ],
  "tags": ["chip", "tag", "label", "filter", "badge"]
}

{
  "name": "Select",
  "displayName": "FlareSelect",
  "category": "Inputs",
  "description": "Dropdown select component with search, multi-select, and virtualization support.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareSelect.html",
  "parameters": [
    { "name": "Value", "type": "TValue", "description": "Gets or sets the selected value", "default": "", "required": false },
    { "name": "ValueChanged", "type": "EventCallback<TValue>", "description": "Callback when selection changes", "default": "", "required": false },
    { "name": "Items", "type": "IEnumerable<TValue>", "description": "Collection of items to select from", "default": "", "required": true },
    { "name": "Label", "type": "string", "description": "Label text", "default": "", "required": false },
    { "name": "Placeholder", "type": "string", "description": "Placeholder when nothing is selected", "default": "", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Color of the select", "default": "Default", "required": false },
    { "name": "Variant", "type": "Variant", "description": "Visual variant", "default": "Outlined", "required": false },
    { "name": "Disabled", "type": "bool", "description": "Whether the select is disabled", "default": "false", "required": false },
    { "name": "Searchable", "type": "bool", "description": "Enable search/filter within the dropdown", "default": "false", "required": false },
    { "name": "Clearable", "type": "bool", "description": "Show a clear button to reset selection", "default": "false", "required": false },
    { "name": "ItemTemplate", "type": "RenderFragment<TValue>", "description": "Template for custom item rendering", "default": "", "required": false },
    { "name": "ValueTemplate", "type": "RenderFragment<TValue>", "description": "Template for selected value rendering", "default": "", "required": false }
  ],
  "events": [
    { "name": "OnChange", "type": "EventCallback<TValue>", "description": "Fired when the selection changes" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareSelect @bind-Value=\"_role\" Label=\"Role\" Items=\"_roles\" />",
    "<FlareSelect @bind-Value=\"_color\" Label=\"Color\" Items=\"_colors\" Searchable=\"true\" Clearable=\"true\" />"
  ],
  "tags": ["input", "select", "dropdown", "form", "choice"]
}

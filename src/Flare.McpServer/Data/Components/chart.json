{
  "name": "Chart",
  "displayName": "FlareChart",
  "category": "DataDisplay",
  "description": "SVG chart component supporting line, bar, pie, and donut charts with theme colors, hover tooltips, and legend.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareChart.html",
  "parameters": [
    { "name": "Type", "type": "ChartType", "description": "Chart type (Line, Bar, Pie, Donut)", "default": "Line", "required": true },
    { "name": "Data", "type": "IEnumerable<ChartDataPoint>", "description": "Chart data points", "default": "", "required": true },
    { "name": "Width", "type": "string", "description": "Chart width (CSS value)", "default": "100%", "required": false },
    { "name": "Height", "type": "string", "description": "Chart height (CSS value)", "default": "300px", "required": false },
    { "name": "ShowLegend", "type": "bool", "description": "Show chart legend", "default": "true", "required": false },
    { "name": "ShowTooltip", "type": "bool", "description": "Show hover tooltips", "default": "true", "required": false },
    { "name": "Colors", "type": "FlareColor[]", "description": "Color array for data series", "default": "", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": [
    "<FlareChart Type=\"ChartType.Bar\" Data=\"_chartData\" ShowLegend=\"true\" />",
    "<FlareChart Type=\"ChartType.Pie\" Data=\"_pieData\" Height=\"400px\" />"
  ],
  "tags": ["chart", "graph", "visualization", "data", "plot", "svg"]
}

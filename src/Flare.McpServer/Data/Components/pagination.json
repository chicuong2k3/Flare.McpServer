{
  "name": "Pagination",
  "displayName": "FlarePagination",
  "category": "Navigation",
  "description": "Pagination component with page buttons, ellipsis, first/last navigation, and page size control.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlarePagination.html",
  "parameters": [
    { "name": "Total", "type": "int", "description": "Total number of items", "default": "0", "required": true },
    { "name": "PageIndex", "type": "int", "description": "Current page (0-based)", "default": "0", "required": false },
    { "name": "PageIndexChanged", "type": "EventCallback<int>", "description": "Callback when page changes", "default": "", "required": false },
    { "name": "PageSize", "type": "int", "description": "Items per page", "default": "10", "required": false },
    { "name": "ShowPageSize", "type": "bool", "description": "Show page size selector", "default": "false", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Color accent", "default": "Default", "required": false }
  ],
  "events": [
    { "name": "OnPageChanged", "type": "EventCallback<int>", "description": "Fired when the page changes" }
  ],
  "subComponents": [],
  "examples": [
    "<FlarePagination Total=\"100\" @bind-PageIndex=\"_page\" PageSize=\"10\" ShowPageSize=\"true\" />"
  ],
  "tags": ["pagination", "page", "navigation", "pager"]
}

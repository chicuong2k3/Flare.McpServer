{
  "name": "Resizable",
  "displayName": "FlareResizable",
  "category": "Layout",
  "description": "Resizable container with drag handles on any edge.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareResizable.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Resizable content", "default": "", "required": true },
    { "name": "MinWidth", "type": "string", "description": "Minimum width", "default": "100px", "required": false },
    { "name": "MinHeight", "type": "string", "description": "Minimum height", "default": "100px", "required": false },
    { "name": "Direction", "type": "ResizeDirection", "description": "Resize direction", "default": "Both", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": ["<FlareResizable MinWidth=\"200px\" MinHeight=\"150px\"><FlareCard>Resize me</FlareCard></FlareResizable>"],
  "tags": ["resize", "drag", "container", "layout"]
}

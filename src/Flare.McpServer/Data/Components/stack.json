{
  "name": "Stack",
  "displayName": "FlareStack",
  "category": "Layout",
  "description": "Flexbox layout component for horizontal or vertical stacking with spacing.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareStack.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Stack children", "default": "", "required": true },
    { "name": "Direction", "type": "StackDirection", "description": "Horizontal or vertical", "default": "Vertical", "required": false },
    { "name": "Spacing", "type": "string", "description": "Spacing between items (CSS value)", "default": "0", "required": false },
    { "name": "Justify", "type": "FlexJustify", "description": "Main axis alignment", "default": "Start", "required": false },
    { "name": "Align", "type": "FlexAlign", "description": "Cross axis alignment", "default": "Start", "required": false },
    { "name": "Wrap", "type": "bool", "description": "Allow wrapping", "default": "false", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": [
    "<FlareStack Direction=\"StackDirection.Vertical\" Spacing=\"1rem\">\n    <FlareText>Item 1</FlareText>\n    <FlareText>Item 2</FlareText>\n</FlareStack>",
    "<FlareStack Direction=\"StackDirection.Horizontal\" Spacing=\"0.5rem\" Align=\"FlexAlign.Center\">\n    <FlareButton>Save</FlareButton>\n    <FlareButton Variant=\"ButtonVariant.Outlined\">Cancel</FlareButton>\n</FlareStack>"
  ],
  "tags": ["layout", "stack", "flex", "container", "spacing"]
}

{
  "name": "Carousel",
  "displayName": "FlareCarousel",
  "category": "DataDisplay",
  "description": "Image/content carousel with slide transitions, autoplay, and navigation controls. Separate package: Flare.Components.Carousel.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareCarousel.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Slide content", "default": "", "required": true },
    { "name": "AutoPlay", "type": "bool", "description": "Auto-advance slides", "default": "false", "required": false },
    { "name": "Interval", "type": "int", "description": "Auto-play interval in ms", "default": "3000", "required": false },
    { "name": "ShowIndicators", "type": "bool", "description": "Show dot indicators", "default": "true", "required": false },
    { "name": "ShowControls", "type": "bool", "description": "Show prev/next arrows", "default": "true", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": ["<FlareCarousel AutoPlay=\"true\">\n    <img src=\"/img1.jpg\" />\n    <img src=\"/img2.jpg\" />\n</FlareCarousel>"],
  "tags": ["carousel", "slideshow", "images", "gallery", "slider"]
}

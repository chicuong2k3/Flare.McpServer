{
  "name": "Overlay",
  "displayName": "FlareOverlay",
  "category": "Overlays",
  "description": "Semi-transparent backdrop used behind dialogs, drawers, and menus.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareOverlay.html",
  "parameters": [
    { "name": "Visible", "type": "bool", "description": "Overlay visibility", "default": "false", "required": false },
    { "name": "Opacity", "type": "double", "description": "Background opacity (0-1)", "default": "0.5", "required": false },
    { "name": "ChildContent", "type": "RenderFragment", "description": "Content rendered on top", "default": "", "required": false }
  ],
  "events": [
    { "name": "OnClick", "type": "EventCallback", "description": "Fired when overlay is clicked" }
  ],
  "subComponents": [],
  "examples": ["<FlareOverlay Visible=\"true\"><FlareProgress Type=\"ProgressType.Circular\" /></FlareOverlay>"],
  "tags": ["overlay", "backdrop", "cover", "mask"]
}

{
  "name": "TextField",
  "displayName": "FlareTextField",
  "category": "Inputs",
  "description": "Text input field with label, placeholder, validation, and icon support.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareTextField.html",
  "parameters": [
    { "name": "Value", "type": "string", "description": "Gets or sets the input value", "default": "", "required": false },
    { "name": "ValueChanged", "type": "EventCallback<string>", "description": "Callback when value changes", "default": "", "required": false },
    { "name": "Label", "type": "string", "description": "Label text displayed above the input", "default": "", "required": false },
    { "name": "Placeholder", "type": "string", "description": "Placeholder text when input is empty", "default": "", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Color of the input (semantic role or custom)", "default": "Default", "required": false },
    { "name": "Variant", "type": "Variant", "description": "Visual variant of the field", "default": "Outlined", "required": false },
    { "name": "Disabled", "type": "bool", "description": "Whether the input is disabled", "default": "false", "required": false },
    { "name": "ReadOnly", "type": "bool", "description": "Whether the input is read-only", "default": "false", "required": false },
    { "name": "Required", "type": "bool", "description": "Whether the input is required", "default": "false", "required": false },
    { "name": "Icon", "type": "string", "description": "Material icon name to display", "default": "", "required": false },
    { "name": "MaxLength", "type": "int?", "description": "Maximum number of characters allowed", "default": "", "required": false },
    { "name": "HelperText", "type": "string", "description": "Helper text displayed below the input", "default": "", "required": false },
    { "name": "AutoFocus", "type": "bool", "description": "Whether to auto-focus the input on page load", "default": "false", "required": false }
  ],
  "events": [
    { "name": "OnChange", "type": "EventCallback<string>", "description": "Fired when the value changes" },
    { "name": "OnBlur", "type": "EventCallback<FocusEventArgs>", "description": "Fired when the input loses focus" },
    { "name": "OnFocus", "type": "EventCallback<FocusEventArgs>", "description": "Fired when the input gains focus" },
    { "name": "OnKeyDown", "type": "EventCallback<KeyboardEventArgs>", "description": "Fired when a key is pressed" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareTextField @bind-Value=\"_name\" Label=\"Name\" />",
    "<FlareTextField @bind-Value=\"_email\" Label=\"Email\" Placeholder=\"user@domain.com\" Icon=\"email\" />"
  ],
  "tags": ["input", "text", "form", "field", "label"]
}

{
  "name": "Alert",
  "displayName": "FlareAlert",
  "category": "Feedback",
  "description": "Alert component for displaying important messages with severity levels, icons, and dismissible support.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareAlert.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Alert message content", "default": "", "required": false },
    { "name": "Severity", "type": "Severity", "description": "Severity level", "default": "Info", "required": false },
    { "name": "Title", "type": "string", "description": "Alert title/heading", "default": "", "required": false },
    { "name": "Icon", "type": "string", "description": "Custom icon (auto-selected by severity if not set)", "default": "", "required": false },
    { "name": "Dismissible", "type": "bool", "description": "Show close button", "default": "false", "required": false },
    { "name": "Outlined", "type": "bool", "description": "Use outlined style", "default": "false", "required": false }
  ],
  "events": [
    { "name": "OnClose", "type": "EventCallback", "description": "Fired when the alert is dismissed" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareAlert Severity=\"Severity.Success\">Operation completed successfully!</FlareAlert>",
    "<FlareAlert Severity=\"Severity.Error\" Title=\"Error\" Dismissible=\"true\">Something went wrong.</FlareAlert>"
  ],
  "tags": ["alert", "message", "notification", "feedback", "banner", "warning"]
}

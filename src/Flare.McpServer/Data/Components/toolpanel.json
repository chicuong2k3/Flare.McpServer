{
  "name": "ToolPanel",
  "displayName": "FlareToolPanel",
  "category": "IDE",
  "description": "Dockable tool panel for IDE layouts like Solution Explorer. Separate package: Flare.Components.IDE.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",

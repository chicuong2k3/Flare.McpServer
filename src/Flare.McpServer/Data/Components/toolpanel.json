  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Panel content", "default": "", "required": true },
    { "name": "Title", "type": "string", "description": "Panel title", "default": "", "required": false },
    { "name": "Position", "type": "Placement", "description": "Docking position", "default": "Right", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": ["<FlareToolPanel Title=\"Solution Explorer\" Position=\"Placement.Right\">\n    <FlareTreeView Items=\"_files\" />\n</FlareToolPanel>"],

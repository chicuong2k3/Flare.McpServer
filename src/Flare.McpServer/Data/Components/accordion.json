{
  "name": "Accordion",
  "displayName": "FlareAccordion",
  "category": "Layout",
  "description": "Expandable accordion with multiple panels, single/multi expand modes.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareAccordion.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "AccordionPanel children", "default": "", "required": true },
    { "name": "ExpandMode", "type": "AccordionExpandMode", "description": "Single or multiple expansion", "default": "Single", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Accent color for expand icon", "default": "Default", "required": false }
  ],
  "events": [],
  "subComponents": ["FlareAccordionPanel"],
  "examples": [
    "<FlareAccordion>\n    <FlareAccordionPanel Title=\"Section 1\">Content 1</FlareAccordionPanel>\n    <FlareAccordionPanel Title=\"Section 2\">Content 2</FlareAccordionPanel>\n</FlareAccordion>"
  ],
  "tags": ["accordion", "expand", "collapse", "panel", "layout"]
}

    { "name": "ChildContent", "type": "RenderFragment", "description": "Form body", "default": "", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": ["<FlareForm Model=\"_user\" OnValidSubmit=\"Save\">\n    <FlareTextField @bind-Value=\"_user.Name\" Label=\"Name\" />\n    <FlareButton Type=\"ButtonType.Submit\">Save</FlareButton>\n</FlareForm>"],
  "tags": ["form", "validation", "editform", "submit"]
}

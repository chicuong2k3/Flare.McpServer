{
  "name": "Progress",
  "displayName": "FlareProgress",
  "category": "Feedback",
  "description": "Progress indicator with linear and circular variants, determinate and indeterminate modes.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareProgress.html",
  "parameters": [
    { "name": "Value", "type": "double", "description": "Progress value (0-100)", "default": "0", "required": false },
    { "name": "Min", "type": "double", "description": "Minimum value", "default": "0", "required": false },
    { "name": "Max", "type": "double", "description": "Maximum value", "default": "100", "required": false },
    { "name": "Type", "type": "ProgressType", "description": "Linear or circular style", "default": "Linear", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Color of the progress bar", "default": "Default", "required": false },
    { "name": "Indeterminate", "type": "bool", "description": "Show indeterminate animation", "default": "false", "required": false },
    { "name": "ShowValue", "type": "bool", "description": "Show percentage text", "default": "false", "required": false },
    { "name": "Size", "type": "Size", "description": "Size of the progress indicator", "default": "Md", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": [
    "<FlareProgress Value=\"70\" Color=\"FlareColor.Success\" />",
    "<FlareProgress Type=\"ProgressType.Circular\" Indeterminate=\"true\" Size=\"Size.Lg\" />"
  ],
  "tags": ["progress", "loading", "indicator", "bar", "circular"]
}

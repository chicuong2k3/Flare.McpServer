{
  "name": "FloatingActionMenu",
  "displayName": "FlareFloatingActionMenu",
  "category": "Buttons",
  "description": "FAB that expands into a radial or vertical menu of action items.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareFloatingActionMenu.html",
  "parameters": [
    { "name": "Icon", "type": "string", "description": "Main FAB icon", "default": "add", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "FAB color", "default": "Primary", "required": false },
    { "name": "ChildContent", "type": "RenderFragment", "description": "Menu items", "default": "", "required": true },
    { "name": "Position", "type": "Placement", "description": "Screen position", "default": "BottomEnd", "required": false }
  ],
  "events": [],
  "subComponents": ["FlareFloatingActionMenuItem"],
  "examples": ["<FlareFloatingActionMenu Icon=\"add\" Color=\"FlareColor.Primary\">\n    <FlareFloatingActionMenuItem Icon=\"person\" OnClick=\"AddUser\" />\n    <FlareFloatingActionMenuItem Icon=\"group\" OnClick=\"AddGroup\" />\n</FlareFloatingActionMenu>"],
  "tags": ["fab", "menu", "floating", "speed-dial", "actions"]
}

{
  "name": "Switch",
  "displayName": "FlareSwitch",
  "category": "Inputs",
  "description": "Toggle switch component for boolean values with label support.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareSwitch.html",
  "parameters": [
    { "name": "Value", "type": "bool", "description": "Gets or sets the toggle state", "default": "false", "required": false },
    { "name": "ValueChanged", "type": "EventCallback<bool>", "description": "Callback when toggle state changes", "default": "", "required": false },
    { "name": "Label", "type": "string", "description": "Label text next to the switch", "default": "", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Color of the switch", "default": "Default", "required": false },
    { "name": "Disabled", "type": "bool", "description": "Whether the switch is disabled", "default": "false", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": [
    "<FlareSwitch @bind-Value=\"_darkMode\" Label=\"Dark Mode\" Color=\"FlareColor.Primary\" />"
  ],
  "tags": ["input", "switch", "toggle", "boolean", "form"]
}

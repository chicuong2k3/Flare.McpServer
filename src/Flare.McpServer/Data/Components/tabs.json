{
  "name": "Tabs",
  "displayName": "FlareTabs",
  "category": "Navigation",
  "description": "Tabbed navigation container with animated active indicator.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareTabs.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Tab content (FlareTab children)", "default": "", "required": true },
    { "name": "ActiveTabIndex", "type": "int", "description": "Gets or sets the active tab index", "default": "0", "required": false },
    { "name": "ActiveTabIndexChanged", "type": "EventCallback<int>", "description": "Callback when active tab changes", "default": "", "required": false },
    { "name": "Position", "type": "TabPosition", "description": "Tab header position", "default": "Top", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Color of the active indicator", "default": "Default", "required": false },
    { "name": "Centered", "type": "bool", "description": "Center the tab headers", "default": "false", "required": false },
    { "name": "Border", "type": "bool", "description": "Show bottom border on headers", "default": "true", "required": false }
  ],
  "events": [
    { "name": "OnTabChange", "type": "EventCallback<int>", "description": "Fired when a tab is selected" }
  ],
  "subComponents": ["FlareTab"],
  "examples": [
    "<FlareTabs @bind-ActiveTabIndex=\"_tabIndex\">\n    <FlareTab Title=\"General\">General content</FlareTab>\n    <FlareTab Title=\"Settings\">Settings content</FlareTab>\n    <FlareTab Title=\"Advanced\">Advanced content</FlareTab>\n</FlareTabs>"
  ],
  "tags": ["navigation", "tabs", "tab", "panel", "container"]
}

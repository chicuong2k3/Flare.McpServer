{
  "name": "Drawer",
  "displayName": "FlareDrawer",
  "category": "Overlays",
  "description": "Slide-out drawer panel from any screen edge for navigation or content.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareDrawer.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Drawer content", "default": "", "required": false },
    { "name": "Visible", "type": "bool", "description": "Gets or sets drawer open state", "default": "false", "required": false },
    { "name": "VisibleChanged", "type": "EventCallback<bool>", "description": "Callback when open state changes", "default": "", "required": false },
    { "name": "Position", "type": "Placement", "description": "Edge the drawer slides from", "default": "Left", "required": false },
    { "name": "Width", "type": "string", "description": "Drawer width (CSS value)", "default": "280px", "required": false },
    { "name": "Modal", "type": "bool", "description": "Show backdrop behind the drawer", "default": "true", "required": false },
    { "name": "CloseOnOverlayClick", "type": "bool", "description": "Close when clicking backdrop", "default": "true", "required": false }
  ],
  "events": [
    { "name": "OnOpen", "type": "EventCallback", "description": "Fired when the drawer opens" },
    { "name": "OnClose", "type": "EventCallback", "description": "Fired when the drawer closes" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareDrawer @bind-Visible=\"_open\" Position=\"Placement.Left\" Width=\"300px\">\n    <FlareNavMenu>\n        <FlareNavLink Href=\"/\" Title=\"Home\" />\n    </FlareNavMenu>\n</FlareDrawer>"
  ],
  "tags": ["drawer", "sidebar", "panel", "overlay", "navigation", "slide"]
}

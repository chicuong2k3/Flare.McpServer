{
  "name": "Skeleton",
  "displayName": "FlareSkeleton",
  "category": "Feedback",
  "description": "Skeleton loading placeholder for text, cards, avatars, and other content shapes.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareSkeleton.html",
  "parameters": [
    { "name": "Width", "type": "string", "description": "Skeleton width (CSS value)", "default": "100%", "required": false },
    { "name": "Height", "type": "string", "description": "Skeleton height (CSS value)", "default": "1rem", "required": false },
    { "name": "Shape", "type": "SkeletonShape", "description": "Shape of the skeleton", "default": "Text", "required": false },
    { "name": "Variant", "type": "SkeletonVariant", "description": "Visual variant (pulse or wave)", "default": "Pulse", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": [
    "<FlareSkeleton Width=\"200px\" Height=\"1.25rem\" />",
    "<FlareSkeleton Shape=\"SkeletonShape.Circle\" Width=\"48px\" Height=\"48px\" />",
    "<FlareSkeleton Shape=\"SkeletonShape.Rectangle\" Width=\"100%\" Height=\"200px\" />"
  ],
  "tags": ["loading", "placeholder", "skeleton", "shimmer", "placeholder"]
}

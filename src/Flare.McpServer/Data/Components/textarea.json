{
  "name": "TextArea",
  "displayName": "FlareTextArea",
  "category": "Inputs",
  "description": "Multi-line text input with auto-resize support.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareTextArea.html",
  "parameters": [
    { "name": "Value", "type": "string", "description": "Gets or sets the text value", "default": "", "required": false },
    { "name": "ValueChanged", "type": "EventCallback<string>", "description": "Callback when value changes", "default": "", "required": false },
    { "name": "Label", "type": "string", "description": "Label text displayed above the textarea", "default": "", "required": false },
    { "name": "Placeholder", "type": "string", "description": "Placeholder text when empty", "default": "", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Color of the textarea", "default": "Default", "required": false },
    { "name": "Variant", "type": "Variant", "description": "Visual variant", "default": "Outlined", "required": false },
    { "name": "Rows", "type": "int", "description": "Number of visible text lines", "default": "3", "required": false },
    { "name": "AutoResize", "type": "bool", "description": "Whether the textarea auto-resizes based on content", "default": "true", "required": false },
    { "name": "MaxRows", "type": "int?", "description": "Maximum rows when AutoResize is enabled", "default": "", "required": false },
    { "name": "Disabled", "type": "bool", "description": "Whether the textarea is disabled", "default": "false", "required": false },
    { "name": "ReadOnly", "type": "bool", "description": "Whether the textarea is read-only", "default": "false", "required": false }
  ],
  "events": [
    { "name": "OnChange", "type": "EventCallback<string>", "description": "Fired when the value changes" },
    { "name": "OnBlur", "type": "EventCallback<FocusEventArgs>", "description": "Fired when the textarea loses focus" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareTextArea @bind-Value=\"_description\" Label=\"Description\" Rows=\"5\" AutoResize=\"true\" />"
  ],
  "tags": ["input", "textarea", "text", "form", "multiline"]
}

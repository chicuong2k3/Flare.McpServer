{
  "name": "InfiniteScroll",
  "displayName": "FlareInfiniteScroll",
  "category": "Layout",
  "description": "Scroll container that triggers data loading when reaching the bottom.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareInfiniteScroll.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Scrollable content", "default": "", "required": true },
    { "name": "HasMore", "type": "bool", "description": "Whether more data is available", "default": "true", "required": false },
    { "name": "Threshold", "type": "int", "description": "Pixels from bottom to trigger load", "default": "200", "required": false }
  ],
  "events": [
    { "name": "OnLoadMore", "type": "EventCallback", "description": "Fired when scrolled near bottom" }
  ],
  "subComponents": [],
  "examples": ["<FlareInfiniteScroll HasMore=\"_hasMore\" OnLoadMore=\"LoadMore\">\n    <FlareVirtualList Items=\"_items\" />\n</FlareInfiniteScroll>"],
  "tags": ["scroll", "infinite", "load", "lazy", "pagination"]
}

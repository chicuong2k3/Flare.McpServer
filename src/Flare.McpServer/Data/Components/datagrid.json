{
  "name": "DataGrid",
  "displayName": "FlareDataGrid",
  "category": "DataDisplay",
  "description": "Advanced data grid with sorting, filtering, paging, grouping, virtualization, column resize, row selection, inline editing, and CSV export.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareDataGrid.html",
  "parameters": [
    { "name": "Items", "type": "IEnumerable<TItem>", "description": "Collection of items to display", "default": "", "required": true },
    { "name": "Filterable", "type": "bool", "description": "Enable per-column filtering", "default": "false", "required": false },
    { "name": "Sortable", "type": "bool", "description": "Enable column sorting", "default": "false", "required": false },
    { "name": "Pageable", "type": "bool", "description": "Enable pagination", "default": "false", "required": false },
    { "name": "PageSize", "type": "int", "description": "Number of rows per page", "default": "10", "required": false },
    { "name": "Virtualize", "type": "bool", "description": "Enable row virtualization for large datasets", "default": "false", "required": false },
    { "name": "Groupable", "type": "bool", "description": "Enable column grouping", "default": "false", "required": false },
    { "name": "Selectable", "type": "bool", "description": "Enable row selection", "default": "false", "required": false },
    { "name": "EditMode", "type": "DataGridEditMode", "description": "Editing mode (Inline or Batch)", "default": "None", "required": false },
    { "name": "Resizable", "type": "bool", "description": "Enable column resizing", "default": "false", "required": false },
    { "name": "Reorderable", "type": "bool", "description": "Enable column reordering", "default": "false", "required": false },
    { "name": "MaxHeight", "type": "string", "description": "Maximum height with scrolling", "default": "", "required": false },
    { "name": "EmptyTemplate", "type": "RenderFragment", "description": "Content shown when no items", "default": "", "required": false },
    { "name": "Loading", "type": "bool", "description": "Shows loading state", "default": "false", "required": false }
  ],
  "events": [
    { "name": "OnRowClick", "type": "EventCallback<TItem>", "description": "Fired when a row is clicked" },
    { "name": "OnPageChanged", "type": "EventCallback<int>", "description": "Fired when page changes" },
    { "name": "OnSelectionChanged", "type": "EventCallback<IReadOnlyCollection<TItem>>", "description": "Fired when row selection changes" }
  ],
  "subComponents": ["FlareColumn", "FlareColumnBand", "FlareColumnRow"],
  "examples": [
    "<FlareDataGrid Items=\"_people\" Filterable=\"true\" Sortable=\"true\" Pageable=\"true\">\n    <FlareColumn Field=\"@nameof(Person.Name)\" Title=\"Name\" />\n    <FlareColumn Field=\"@nameof(Person.Age)\" Title=\"Age\" Align=\"ColumnAlign.End\" />\n</FlareDataGrid>"
  ],
  "tags": ["data", "grid", "table", "sort", "filter", "pagination", "virtualization"]
}

{
  "name": "Checkbox",
  "displayName": "FlareCheckbox",
  "category": "Inputs",
  "description": "Checkbox component for boolean values with label and indeterminate state.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareCheckbox.html",
  "parameters": [
    { "name": "Value", "type": "bool", "description": "Gets or sets the checked state", "default": "false", "required": false },
    { "name": "ValueChanged", "type": "EventCallback<bool>", "description": "Callback when checked state changes", "default": "", "required": false },
    { "name": "Label", "type": "string", "description": "Label text next to the checkbox", "default": "", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Color of the checkbox", "default": "Default", "required": false },
    { "name": "Disabled", "type": "bool", "description": "Whether the checkbox is disabled", "default": "false", "required": false },
    { "name": "Indeterminate", "type": "bool", "description": "Shows indeterminate state", "default": "false", "required": false },
    { "name": "ChildContent", "type": "RenderFragment", "description": "Custom label content (can include links/formatting)", "default": "", "required": false }
  ],
  "events": [
    { "name": "OnChange", "type": "EventCallback<ChangeEventArgs>", "description": "Fired when the checked state changes" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareCheckbox @bind-Value=\"_agree\">I agree to the terms</FlareCheckbox>",
    "<FlareCheckbox @bind-Value=\"_enabled\" Color=\"FlareColor.Success\" Label=\"Enable feature\" />"
  ],
  "tags": ["input", "checkbox", "toggle", "boolean", "form"]
}

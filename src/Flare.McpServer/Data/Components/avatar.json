{
  "name": "Avatar",
  "displayName": "FlareAvatar",
  "category": "Display",
  "description": "Avatar component for user profile images, initials, or icons with grouping support.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareAvatar.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Initials or icon content", "default": "", "required": false },
    { "name": "Src", "type": "string", "description": "Image source URL", "default": "", "required": false },
    { "name": "Alt", "type": "string", "description": "Alt text for the image", "default": "", "required": false },
    { "name": "Size", "type": "Size", "description": "Avatar size", "default": "Md", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Background color for initials", "default": "Default", "required": false },
    { "name": "Shape", "type": "AvatarShape", "description": "Circle or square shape", "default": "Circle", "required": false },
    { "name": "Online", "type": "bool?", "description": "Show online/offline status indicator", "default": "", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": [
    "<FlareAvatar Src=\"/images/user.png\" Alt=\"User\" />",
    "<FlareAvatar Color=\"FlareColor.Primary\">JD</FlareAvatar>",
    "<FlareAvatar Online=\"true\" Src=\"/images/user.png\" Size=\"Size.Lg\" />"
  ],
  "tags": ["avatar", "profile", "image", "user", "initials", "icon"]
}

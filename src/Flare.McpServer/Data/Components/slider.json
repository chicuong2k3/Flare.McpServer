{
  "name": "Slider",
  "displayName": "FlareSlider",
  "category": "Inputs",
  "description": "Slider for selecting a numeric value or range with MD3 Expressive + Fluent support.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareSlider.html",
  "parameters": [
    { "name": "Value", "type": "int", "description": "Gets or sets the slider value", "default": "0", "required": false },
    { "name": "ValueChanged", "type": "EventCallback<int>", "description": "Callback when value changes", "default": "", "required": false },
    { "name": "Min", "type": "int", "description": "Minimum value", "default": "0", "required": false },
    { "name": "Max", "type": "int", "description": "Maximum value", "default": "100", "required": false },
    { "name": "Step", "type": "int", "description": "Step increment", "default": "1", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Color of the slider track", "default": "Default", "required": false },
    { "name": "Size", "type": "Size", "description": "Size of the slider", "default": "Md", "required": false },
    { "name": "Disabled", "type": "bool", "description": "Whether the slider is disabled", "default": "false", "required": false },
    { "name": "ShowValueLabel", "type": "bool", "description": "Show the current value bubble", "default": "false", "required": false },
    { "name": "Vertical", "type": "bool", "description": "Render as vertical slider", "default": "false", "required": false }
  ],
  "events": [
    { "name": "OnChange", "type": "EventCallback<int>", "description": "Fired when the value changes" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareSlider @bind-Value=\"_volume\" Min=\"0\" Max=\"100\" />",
    "<FlareSlider @bind-Value=\"_progress\" Color=\"FlareColor.Primary\" ShowValueLabel=\"true\" />"
  ],
  "tags": ["input", "slider", "range", "number", "form"]
}

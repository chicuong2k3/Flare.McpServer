{
  "name": "SplitButton",
  "displayName": "FlareSplitButton",
  "category": "Buttons",
  "description": "Button with a dropdown menu for additional actions. Main action + more options pattern.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareSplitButton.html",
  "parameters": [
    { "name": "Text", "type": "string", "description": "Main button label", "default": "", "required": false },
    { "name": "Variant", "type": "ButtonVariant", "description": "Visual variant", "default": "Filled", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Button color", "default": "Default", "required": false },
    { "name": "MenuItems", "type": "RenderFragment", "description": "Dropdown menu items", "default": "", "required": true }
  ],
  "events": [
    { "name": "OnClick", "type": "EventCallback", "description": "Fired when main action clicked" }
  ],
  "subComponents": [],
  "examples": ["<FlareSplitButton Text=\"Save\" OnClick=\"Save\" Variant=\"ButtonVariant.Filled\">\n    <FlareMenuItem>Save and close</FlareMenuItem>\n    <FlareMenuItem>Save as draft</FlareMenuItem>\n</FlareSplitButton>"],
  "tags": ["button", "split", "dropdown", "menu", "actions"]
}

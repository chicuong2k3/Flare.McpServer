{
  "name": "Rating",
  "displayName": "FlareRating",
  "category": "Inputs",
  "description": "Star rating input with customizable count, size, and color.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareRating.html",
  "parameters": [
    { "name": "Value", "type": "int", "description": "Rating value (0 to Max)", "default": "0", "required": false },
    { "name": "ValueChanged", "type": "EventCallback<int>", "description": "Callback when rating changes", "default": "", "required": false },
    { "name": "Max", "type": "int", "description": "Maximum rating (number of stars)", "default": "5", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Star color", "default": "Default", "required": false },
    { "name": "Size", "type": "Size", "description": "Star size", "default": "Md", "required": false },
    { "name": "ReadOnly", "type": "bool", "description": "Display-only, not interactive", "default": "false", "required": false },
    { "name": "Disabled", "type": "bool", "description": "Whether rating is disabled", "default": "false", "required": false }
  ],
  "events": [
    { "name": "OnChange", "type": "EventCallback<int>", "description": "Fired when rating value changes" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareRating @bind-Value=\"_rating\" Max=\"5\" Color=\"FlareColor.Warning\" />",
    "<FlareRating Value=\"4\" ReadOnly=\"true\" Size=\"Size.Sm\" />"
  ],
  "tags": ["rating", "stars", "input", "feedback", "review"]
}

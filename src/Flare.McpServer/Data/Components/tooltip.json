{
  "name": "Tooltip",
  "displayName": "FlareTooltip",
  "category": "Overlays",
  "description": "Tooltip overlay that shows contextual help text on hover or focus.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareTooltip.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "The trigger element", "default": "", "required": true },
    { "name": "Text", "type": "string", "description": "Tooltip text content", "default": "", "required": true },
    { "name": "Position", "type": "Placement", "description": "Tooltip position relative to trigger", "default": "Top", "required": false },
    { "name": "Delay", "type": "int", "description": "Delay before showing (ms)", "default": "400", "required": false },
    { "name": "TooltipContent", "type": "RenderFragment", "description": "Custom tooltip content (overrides Text)", "default": "", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": [
    "<FlareTooltip Text=\"Copy to clipboard\" Position=\"Placement.Top\">\n    <FlareButton Icon=\"content_copy\" Variant=\"ButtonVariant.Outlined\" />\n</FlareTooltip>"
  ],
  "tags": ["tooltip", "help", "hint", "overlay", "popup"]
}

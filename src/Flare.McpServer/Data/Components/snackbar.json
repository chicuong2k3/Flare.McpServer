{
  "name": "Snackbar",
  "displayName": "FlareSnackbarProvider",
  "category": "Feedback",
  "description": "Snackbar notification system. Use ISnackbarService to show notifications programmatically.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareSnackbar.html",
  "parameters": [
    { "name": "MaxDisplayed", "type": "int", "description": "Maximum concurrent snackbars", "default": "5", "required": false },
    { "name": "Position", "type": "Placement", "description": "Position of snackbars", "default": "BottomEnd", "required": false },
    { "name": "Timeout", "type": "int", "description": "Auto-dismiss timeout in ms (0 = sticky)", "default": "5000", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": [
    "<FlareSnackbarProvider />",
    "Snackbar.Show(\"Record deleted\", SnackbarSeverity.Success);",
    "Snackbar.Show(\"Error occurred\", SnackbarSeverity.Error, icon: \"error\");"
  ],
  "tags": ["notification", "toast", "snackbar", "message", "feedback", "alert"]
}

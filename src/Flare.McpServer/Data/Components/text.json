{
  "name": "Text",
  "displayName": "FlareText",
  "category": "Display",
  "description": "Typography component for rendering text with theme-aware type scales and colors.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareText.html",
  "parameters": [
    { "name": "ChildContent", "type": "RenderFragment", "description": "Text content", "default": "", "required": false },
    { "name": "Typo", "type": "TypographyScale", "description": "Typography scale preset", "default": "BodyMedium", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Text color", "default": "Default", "required": false },
    { "name": "Align", "type": "TextAlign", "description": "Text alignment", "default": "Start", "required": false },
    { "name": "Truncate", "type": "bool", "description": "Truncate overflow with ellipsis", "default": "false", "required": false },
    { "name": "Nowrap", "type": "bool", "description": "Prevent text wrapping", "default": "false", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": [
    "<FlareText Typo=\"TypographyScale.HeadlineMedium\">Page Title</FlareText>",
    "<FlareText Typo=\"TypographyScale.BodyMedium\" Color=\"FlareColor.OnSurfaceVariant\">Secondary text</FlareText>"
  ],
  "tags": ["text", "typography", "title", "heading", "paragraph"]
}

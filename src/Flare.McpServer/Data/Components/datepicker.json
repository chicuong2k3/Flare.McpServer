{
  "name": "DatePicker",
  "displayName": "FlareDatePicker",
  "category": "Inputs",
  "description": "Date picker with calendar popup, min/max dates, and format options.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
  "apiUrl": "https://jrfrigat.github.io/Flare/api/FlareDatePicker.html",
  "parameters": [
    { "name": "Value", "type": "DateTime?", "description": "Selected date", "default": "", "required": false },
    { "name": "ValueChanged", "type": "EventCallback<DateTime?>", "description": "Callback when date changes", "default": "", "required": false },
    { "name": "Label", "type": "string", "description": "Field label", "default": "", "required": false },
    { "name": "Min", "type": "DateTime?", "description": "Earliest selectable date", "default": "", "required": false },
    { "name": "Max", "type": "DateTime?", "description": "Latest selectable date", "default": "", "required": false },
    { "name": "Format", "type": "string", "description": "Display format", "default": "yyyy-MM-dd", "required": false },
    { "name": "Color", "type": "FlareColor", "description": "Color theme", "default": "Default", "required": false },
    { "name": "Disabled", "type": "bool", "description": "Whether the picker is disabled", "default": "false", "required": false },
    { "name": "Clearable", "type": "bool", "description": "Show clear button", "default": "false", "required": false }
  ],
  "events": [
    { "name": "OnChange", "type": "EventCallback<DateTime?>", "description": "Fired when date changes" }
  ],
  "subComponents": [],
  "examples": [
    "<FlareDatePicker @bind-Value=\"_birthDate\" Label=\"Birth Date\" Min=\"@DateTime.Now.AddYears(-100)\" Max=\"@DateTime.Now\" />"
  ],
  "tags": ["datepicker", "calendar", "date", "input", "form"]
}

  "parameters": [
    { "name": "Code", "type": "string", "description": "Source code text", "default": "", "required": true },
    { "name": "Language", "type": "string", "description": "Programming language (csharp, js, html, etc.)", "default": "", "required": false },
    { "name": "ShowLineNumbers", "type": "bool", "description": "Show line numbers", "default": "true", "required": false },
    { "name": "ShowCopy", "type": "bool", "description": "Show copy button", "default": "true", "required": false }
  ],
  "events": [],
  "subComponents": [],
  "examples": ["<FlareCodeBlock Code=\"@code\" Language=\"csharp\" ShowLineNumbers=\"true\" />"],

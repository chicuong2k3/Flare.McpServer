{
  "name": "CodeBlock",
  "displayName": "FlareCodeBlock",
  "category": "Display",
  "description": "Syntax-highlighted code block with line numbers, copy button, and language detection.",
  "docUrl": "https://github.com/jrfrigat/Flare/blob/main/docs/en/ai-agents.md",
